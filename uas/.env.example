# =====================
# Server Port Configuration
# =====================
CORE_SERVICE_PORT=8001
SEARCH_SERVICE_PORT=8002
FRONTEND_PORT=3000

# =====================
# MongoDB Configuration
# =====================
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB_NAME=toko_komputer
MONGO_COLLECTION_NAME=produk

# =====================
# Elasticsearch Configuration
# =====================
ELASTIC_HOST=elasticsearch
ELASTIC_PORT=9200
ELASTIC_INDEX_NAME=produk

# =====================
# Service URLs (for inter-service communication)
# =====================
SEARCH_SERVICE_URL=http://search-service:8002

# =====================
# Dataset Path (inside container)
# =====================
DATASET_PATH=/app/data/products.json

# =====================
# Frontend Environment (Vite)
# =====================
VITE_CORE_SERVICE_URL=http://localhost:8001/api
VITE_SEARCH_SERVICE_URL=http://localhost:8002/api